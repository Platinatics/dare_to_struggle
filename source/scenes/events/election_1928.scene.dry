    Q.new_middle_ccf -= 5;
    Q.old_middle_ccf -= 5;
    Q.rural_ccf -= 5;
    Q.catholics_ccf -= 3;
    Q.workers_nsdap += 5;
    Q.old_middle_nsdap += 5;
    Q.new_middle_nsdap += 5;
    Q.rural_nsdap += 5;
    Q.unemployed_nsdap += 5;   
}
!}
